#!/bin/sh
# postinst for qiftop-agent
set -e

# Use bare command names so lintian doesn't flag absolute paths in
# maintainer scripts. PATH is set to a sane default by dpkg.

# Ensure the `netdev` group exists (it's standard on Debian/Ubuntu via
# `base-passwd`, but the DBus policy in dist/dbus/ depends on it). Members
# of this group are permitted to talk to org.qiftop.NetworkAgent1; users
# not in it will see the GUI fall back to its in-process (self-elevated)
# backend.
if ! getent group netdev >/dev/null 2>&1; then
    if command -v groupadd >/dev/null 2>&1; then
        groupadd -r netdev || true
    elif command -v addgroup >/dev/null 2>&1; then
        addgroup --system netdev || true
    fi
fi

# Auto-enroll the installing user into `netdev` so the GUI can reach the
# agent immediately after `apt install` without the user having to hunt
# down the relevant usermod command. We try, in order:
#   1. $SUDO_USER (set when the install ran under `sudo`)
#   2. $PKEXEC_UID (set when the install ran via pkexec, e.g. from a
#      graphical package manager)
# We skip root and any user already in the group. A no-op `|| true`
# guards every step — a failure here must never break the install.
target_user=""
if [ -n "${SUDO_USER:-}" ] && [ "${SUDO_USER}" != "root" ]; then
    target_user="${SUDO_USER}"
elif [ -n "${PKEXEC_UID:-}" ]; then
    target_user="$(getent passwd "${PKEXEC_UID}" 2>/dev/null | cut -d: -f1 || true)"
fi
if [ -n "${target_user}" ] && getent passwd "${target_user}" >/dev/null 2>&1; then
    if ! id -nG "${target_user}" 2>/dev/null | tr ' ' '\n' | grep -qx netdev; then
        if command -v usermod >/dev/null 2>&1; then
            usermod -a -G netdev "${target_user}" || true
            echo "qiftop-agent: added user '${target_user}' to group 'netdev'." >&2
            echo "qiftop-agent: log out and back in (or run 'newgrp netdev') for the change to take effect." >&2
        fi
    fi
fi

if command -v systemctl >/dev/null 2>&1; then
    systemctl daemon-reload || true
    systemctl reload dbus.service 2>/dev/null || true
fi

exit 0
