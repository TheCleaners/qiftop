# -*- mode: ruby -*-
# vi: ft=ruby
#
# Disposable ubuntu-24.04 VM that mirrors the GitHub Actions runner
# image used by .github/workflows/integration.yml. Spin it up to run
# the attribution Tier-2 harness without the host's logind / sudo /
# kernel-module quirks affecting the result.
#
# Usage from the repo root:
#   ./scripts/local-integration.sh                  # run all runtimes
#   ./scripts/local-integration.sh --runtime podman # just podman
#
# Manual usage:
#   cd tests/integration/vagrant
#   vagrant up
#   vagrant ssh -c 'cd /home/vagrant/qiftop && \
#       cmake -S . -B build -DQIFTOP_BUILD_ATTRIBUTION_INTEGRATION=ON && \
#       cmake --build build --target qiftop-attribution-probe -j && \
#       sudo ctest --test-dir build -L attribution-integration --output-on-failure -V'
#
# Tear down with `vagrant destroy -f` when done; the VM is intended to
# be ephemeral.

REPO_ROOT = File.expand_path("../../..", __dir__)

Vagrant.configure("2") do |config|
  # Ubuntu 24.04 LTS — exact same generation as the CI runner image.
  # 'bento/ubuntu-24.04' supports libvirt and is actively maintained.
  config.vm.box = "bento/ubuntu-24.04"
  config.vm.hostname = "qiftop-integration"

  config.vm.provider "libvirt" do |lv|
    # Default to the system libvirt instance — vagrant-libvirt's
    # session mode forces qemu-bridge-helper for the management
    # network, which needs both /etc/qemu/bridge.conf ACL edits AND
    # setuid on the helper (more invasive than the standard libvirt
    # group setup). With qemu:///system the libvirt 'default' NAT
    # network just works.
    #
    # Polkit lets members of the 'libvirt' group access qemu:///system
    # without a password. If you get a polkit prompt, add yourself once:
    #   sudo usermod -aG libvirt $USER && newgrp libvirt
    #
    # Override via LIBVIRT_DEFAULT_URI if you really want session mode
    # (you'll also need /etc/qemu/bridge.conf + setuid helper).
    lv.uri = ENV.fetch("LIBVIRT_DEFAULT_URI", "qemu:///system")
    lv.memory = 4096
    lv.cpus   = 4
    lv.machine_virtual_size = 20
  end

  # Disable vagrant's default /vagrant synced folder — it tries NFS by
  # default with libvirt, which needs host-side nfsd config we don't
  # want to require. Our explicit rsync share below is the only one
  # we actually use.
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # rsync the repo into the guest. NFS/9p would be faster but rsync
  # works without any extra host config and matches what CI sees (a
  # clean checkout, not a live-mounted dev tree).
  config.vm.synced_folder REPO_ROOT, "/home/vagrant/qiftop",
    type: "rsync",
    rsync__exclude: [
      ".git/",
      "build/", "build-*/",
      ".vagrant/",
      "*.iso", "*.box",
      "tests/integration/vagrant/.vagrant/",
    ],
    rsync__args: ["--archive", "--delete", "--compress"]

  config.vm.provision "shell",
    path: "provision.sh",
    privileged: true,
    keep_color: true
end
