# -*- mode: ruby -*-
# vi: ft=ruby
#
# Disposable VMs for the qiftop attribution Tier-2 harness. Two machines:
#
#   ubuntu  (primary, default)  bento/ubuntu-24.04
#       Mirrors the GitHub Actions runner image used by
#       .github/workflows/integration.yml. Runs the full set of
#       attribution runners (docker, podman, k3d, k8s, systemd-dbus).
#
#   fedora  (autostart: false)  generic/fedora41
#       SELinux-ENFORCING host. Exists to exercise the two things the
#       Ubuntu VM cannot: (a) the agent's systemd unit + DBus policy
#       under SELinux, and (b) the real .rpm install path on Fedora.
#       Scoped to the systemd-dbus runner. Override the box with
#       QIFTOP_FEDORA_BOX (e.g. fedora/41-cloud-base — note: must
#       include rsync for the synced folder).
#
# Usage from the repo root (see scripts/local-integration.sh):
#   ./scripts/local-integration.sh                       # ubuntu, all runtimes
#   ./scripts/local-integration.sh --distro fedora       # fedora, systemd-dbus + SELinux
#   ./scripts/local-integration.sh --runtime podman      # ubuntu, just podman
#
# Manual usage:
#   cd tests/integration/vagrant
#   vagrant up ubuntu                # or: vagrant up fedora
#   vagrant ssh fedora -c '...'
#
# Tear down with `vagrant destroy -f` when done; the VMs are ephemeral.
#
# NOTE: this file was previously single-machine (the default 'default'
# machine). After this change the machines are named 'ubuntu' and
# 'fedora'. If you have an old 'default' VM lying around, drop it with
# `vagrant destroy default` (its state dir is gitignored).

REPO_ROOT = File.expand_path("../../..", __dir__)

# Shared per-machine setup (provider sizing + rsync share + provisioner).
# Kept in a lambda so the two define blocks below stay DRY.
configure_node = lambda do |node, provision_script|
  node.vm.provider "libvirt" do |lv|
    # Default to the system libvirt instance — vagrant-libvirt's
    # session mode forces qemu-bridge-helper for the management
    # network, which needs both /etc/qemu/bridge.conf ACL edits AND
    # setuid on the helper (more invasive than the standard libvirt
    # group setup). With qemu:///system the libvirt 'default' NAT
    # network just works.
    #
    # Polkit lets members of the 'libvirt' group access qemu:///system
    # without a password. If you get a polkit prompt, add yourself once:
    #   sudo usermod -aG libvirt $USER && newgrp libvirt
    lv.uri = ENV.fetch("LIBVIRT_DEFAULT_URI", "qemu:///system")
    lv.memory = 4096
    lv.cpus   = 4
    lv.machine_virtual_size = 20
  end

  # rsync the repo into the guest. NFS/9p would be faster but rsync
  # works without any extra host config and matches what CI sees (a
  # clean checkout, not a live-mounted dev tree). The guest box MUST
  # ship rsync for this to work at `vagrant up` time.
  node.vm.synced_folder REPO_ROOT, "/home/vagrant/qiftop",
    type: "rsync",
    rsync__exclude: [
      ".git/",
      "build/", "build-*/",
      ".vagrant/",
      "*.iso", "*.box",
      "tests/integration/vagrant/.vagrant/",
    ],
    rsync__args: ["--archive", "--delete", "--compress"]

  node.vm.provision "shell",
    path: provision_script,
    privileged: true,
    keep_color: true
end

Vagrant.configure("2") do |config|
  # Disable vagrant's default /vagrant synced folder — it tries NFS by
  # default with libvirt, which needs host-side nfsd config we don't
  # want to require. The explicit rsync share above is the only one used.
  config.vm.synced_folder ".", "/vagrant", disabled: true

  # --- Ubuntu (primary): full attribution runner set --------------------
  config.vm.define "ubuntu", primary: true do |node|
    # Ubuntu 24.04 LTS — exact same generation as the CI runner image.
    node.vm.box      = "bento/ubuntu-24.04"
    node.vm.hostname = "qiftop-ubuntu"
    configure_node.call(node, "provision.sh")
  end

  # --- Fedora (opt-in): SELinux-enforcing systemd-dbus + rpm path -------
  # autostart: false so a bare `vagrant up` only brings up Ubuntu; the
  # Fedora VM is summoned explicitly (`vagrant up fedora` /
  # `local-integration.sh --distro fedora`).
  config.vm.define "fedora", autostart: false do |node|
    node.vm.box      = ENV.fetch("QIFTOP_FEDORA_BOX", "generic/fedora41")
    node.vm.hostname = "qiftop-fedora"
    configure_node.call(node, "provision-fedora.sh")
  end
end
